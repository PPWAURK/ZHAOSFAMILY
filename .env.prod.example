# Root .env consumed by `docker compose -f docker-compose.prod.yml` for
# variable interpolation (MySQL + MinIO containers).
# Copy to `.env` on the server and fill with real secrets. Do NOT commit `.env`.

MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=zhao_family
MYSQL_USER=zhao
MYSQL_PASSWORD=change_me_db

MINIO_ROOT_USER=zhaominio
MINIO_ROOT_PASSWORD=change_me_minio
