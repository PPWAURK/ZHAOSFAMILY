# Keep the docker build context small and deterministic.
.git
.github
**/node_modules
**/dist
**/.next
**/.expo
**/.turbo
**/coverage
**/out
pnpm-debug.log*
**/*.tsbuildinfo
**/*.log
**/.DS_Store

# Local env / secrets — never enter the image (mounted at runtime via env_file)
**/.env
**/.env.*

# Native build outputs
apps/mobile/android
apps/mobile/ios
apps/web/out

# Repo cruft not part of the backend build
backups
*.sql
ZHAO 2
