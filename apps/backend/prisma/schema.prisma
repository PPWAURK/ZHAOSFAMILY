generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                         Int                        @id @default(autoincrement())
  familyName                 String                     @map("family_name")
  givenName                  String                     @map("given_name")
  name                       String
  email                      String                     @unique
  emailVerified              Boolean                    @default(false) @map("email_verified")
  accountStatus              String                     @default("approved") @map("account_status") @db.VarChar(20)
  accountReviewedAt          DateTime?                  @map("account_reviewed_at")
  accountReviewedByUserId    Int?                       @map("account_reviewed_by_user_id")
  passwordHash               String                     @map("password_hash")
  restaurantId               Int                        @map("restaurant_id")
  restaurant                 Restaurant                 @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  birthday                   DateTime?                  @db.Date
  jobRole                    String?                    @map("job_role")
  phone                      String?                    @db.VarChar(50)
  address                    String?                    @db.VarChar(255)
  profilePhoto               String?                    @map("profile_photo") @db.LongText
  equippedTrainingTitleCode  String?                    @map("equipped_training_title_code") @db.VarChar(40)
  userLevel                  Int                        @default(0) @map("user_level") @db.UnsignedTinyInt
  acceptedTerms              Boolean                    @default(false) @map("accepted_terms")
  preferredLanguage          String                     @default("fr") @map("preferred_language")
  invitationTokenHash        String?                    @map("invitation_token_hash") @db.VarChar(64)
  invitationExpiresAt        DateTime?                  @map("invitation_expires_at")
  passwordResetTokenHash     String?                    @map("password_reset_token_hash") @db.VarChar(64)
  passwordResetExpiresAt     DateTime?                  @map("password_reset_expires_at")
  createdAt                  DateTime                   @default(now()) @map("created_at")
  updatedAt                  DateTime                   @updatedAt @map("updated_at")
  userRoles                  UserRole[]
  purchaseOrders             PurchaseOrder[]            @relation("CreatedByUser")
  purchaseReturns            PurchaseReturn[]           @relation("CreatedByUserReturns")
  trainingProgress           TrainingMaterialProgress[]
  trainingQuizAttempts       TrainingQuizAttempt[]
  screenSecurityEvents       ScreenSecurityEvent[]
  trainingTitles             UserTrainingTitle[]
  equippedTrainingTitle      TrainingTitle?             @relation("EquippedTrainingTitle", fields: [equippedTrainingTitleCode], references: [code], onDelete: SetNull)
  trainingBadges             UserTrainingBadge[]
  dashboardPosts             DashboardPost[]            @relation("DashboardPostAuthor")
  refreshSessions            RefreshSession[]
  pushTokens                 PushToken[]
  notifications              Notification[]
  createdRecruitmentRequests RecruitmentRequest[]       @relation("RecruitmentRequestCreatedBy")
  handledRecruitmentRequests RecruitmentRequest[]       @relation("RecruitmentRequestHandledBy")
  caseShares                 CaseShare[]                @relation("CaseShareAuthor")
  reviewedCaseShares         CaseShare[]                @relation("CaseShareReviewedBy")
  caseShareComments          CaseShareComment[]         @relation("CaseShareCommentAuthor")
  caseShareLikes             CaseShareLike[]            @relation("CaseShareLikeUser")
  createdRecipes             Recipe[]                   @relation("RecipeCreatedBy")
  updatedRecipes             Recipe[]                   @relation("RecipeUpdatedBy")

  @@index([restaurantId])
  @@index([accountStatus])
  @@index([equippedTrainingTitleCode])
  @@index([invitationTokenHash])
  @@index([passwordResetTokenHash])
  @@map("users")
}

model RefreshSession {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_sessions")
}

model PushToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  token      String    @unique @db.VarChar(255)
  platform   String    @db.VarChar(20)
  deviceName String?   @map("device_name") @db.VarChar(120)
  disabledAt DateTime? @map("disabled_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  type      String    @db.VarChar(50)
  title     String    @db.VarChar(200)
  body      String    @db.Text
  data      Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique @db.VarChar(100)
  description     String?          @db.VarChar(255)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              Int              @id @default(autoincrement())
  key             String           @unique @db.VarChar(150)
  description     String?          @db.VarChar(255)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Restaurant {
  id                  Int                  @id @default(autoincrement())
  name                String               @unique
  address             String
  photoUrl            String?              @map("photo_url")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @map("updated_at")
  users               User[]
  purchaseOrders      PurchaseOrder[]
  purchaseReturns     PurchaseReturn[]
  dashboardPosts      DashboardPost[]
  recruitmentRequests RecruitmentRequest[]
  abcStoreScores      AbcStoreScore[]
  caseShares          CaseShare[]
  waitingQueueEntries WaitingQueueEntry[]

  @@map("restaurants")
}

model AbcScoreCycle {
  id          Int             @id @default(autoincrement())
  label       String          @db.VarChar(120)
  status      String          @default("draft") @db.VarChar(20)
  publishedAt DateTime?       @map("published_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  scores      AbcStoreScore[]

  @@index([status, createdAt])
  @@map("abc_score_cycles")
}

model AbcStoreScore {
  id                       Int             @id @default(autoincrement())
  cycleId                  Int             @map("cycle_id")
  restaurantId             Int             @map("restaurant_id")
  marketingScore           Int?            @map("marketing_score")
  marketingNotes           String?         @map("marketing_notes") @db.Text
  marketingFilledByUserId  Int?            @map("marketing_filled_by_user_id")
  marketingFilledAt        DateTime?       @map("marketing_filled_at")
  operationsScore          Int?            @map("operations_score")
  operationsNotes          String?         @map("operations_notes") @db.Text
  operationsFilledByUserId Int?            @map("operations_filled_by_user_id")
  operationsFilledAt       DateTime?       @map("operations_filled_at")
  grade                    String?         @db.VarChar(1)
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")
  cycle                    AbcScoreCycle   @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  restaurant               Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  media                    AbcScoreMedia[]

  @@unique([cycleId, restaurantId])
  @@index([restaurantId])
  @@map("abc_store_scores")
}

model AbcScoreMedia {
  id               Int           @id @default(autoincrement())
  storeScoreId     Int           @map("store_score_id")
  objectKey        String        @map("object_key") @db.VarChar(512)
  fileName         String?       @map("file_name") @db.VarChar(255)
  department       String        @default("operations") @db.VarChar(20)
  uploadedByUserId Int?          @map("uploaded_by_user_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  storeScore       AbcStoreScore @relation(fields: [storeScoreId], references: [id], onDelete: Cascade)

  @@index([storeScoreId])
  @@map("abc_score_media")
}

model Product {
  id                BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  supplierId        Int      @map("supplier_id")
  reference         String?  @db.VarChar(100)
  category          String   @map("categorie") @db.VarChar(20)
  nameCn            String   @map("nom_cn") @db.VarChar(255)
  designationFr     String?  @map("designation_fr") @db.VarChar(255)
  unit              String?  @map("unite") @db.VarChar(100)
  unitPriceHt       Decimal? @map("prix_u_ht") @db.Decimal(10, 2)
  image             String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  specification     String?  @db.VarChar(100)
  specification2    String?  @map("specification_2") @db.VarChar(100)
  specification3    String?  @map("specification_3") @db.VarChar(100)
  unit2             String?  @map("unit_2") @db.VarChar(100)
  unit3             String?  @map("unit_3") @db.VarChar(100)
  unitPriceHt2      Decimal? @map("prix_u_ht_2") @db.Decimal(10, 2)
  unitPriceHt3      Decimal? @map("prix_u_ht_3") @db.Decimal(10, 2)
  isActive          Boolean  @default(true) @map("is_active")
  productCategoryId Int?     @map("product_category_id")

  supplier            Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  inventoryMovements  InventoryMovement[]
  purchaseOrderItems  PurchaseOrderItem[]
  purchaseReturnItems PurchaseReturnItem[]

  @@index([supplierId])
  @@map("products")
}

model InventoryMovement {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  productId BigInt   @map("product_id") @db.UnsignedBigInt
  delta     Int
  reason    String?  @db.VarChar(255)
  source    String   @default("manual") @db.VarChar(50)
  sourceId  String?  @map("source_id") @db.VarChar(100)
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model Supplier {
  id                        Int              @id @default(autoincrement())
  name                      String           @map("nom") @db.VarChar(255)
  sortOrder                 Int              @map("sort_order")
  includeAllProductsInOrder Boolean          @default(false) @map("include_all_products_in_order")
  orderNotice               String?          @map("order_notice") @db.Text
  products                  Product[]
  purchaseOrders            PurchaseOrder[]
  purchaseReturns           PurchaseReturn[]

  @@index([sortOrder])
  @@map("fournisseurs")
}

model PurchaseOrder {
  id              Int                 @id @default(autoincrement())
  number          String              @unique @db.VarChar(50)
  supplierId      Int                 @map("supplier_id")
  supplier        Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  restaurantId    Int                 @map("restaurant_id")
  restaurant      Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  createdByUserId Int                 @map("created_by_user_id")
  createdByUser   User                @relation("CreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  deliveryDate    DateTime            @map("delivery_date") @db.Date
  deliveryAddress String              @map("delivery_address") @db.VarChar(255)
  totalItems      Int                 @map("total_items")
  totalAmount     Decimal             @map("total_amount") @db.Decimal(10, 2)
  bonFileName     String              @map("bon_file_name") @db.VarChar(191)
  items           PurchaseOrderItem[]
  returns         PurchaseReturn[]
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([restaurantId, createdAt])
  @@index([supplierId, createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                Int                  @id @default(autoincrement())
  purchaseOrderId   Int                  @map("purchase_order_id")
  purchaseOrder     PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId         BigInt               @map("product_id") @db.UnsignedBigInt
  product           Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplierId        Int                  @map("supplier_id")
  specificationSlot Int?                 @map("specification_slot")
  quantity          Int
  unitPriceHt       Decimal              @map("unit_price_ht") @db.Decimal(10, 2)
  lineTotal         Decimal              @map("line_total") @db.Decimal(10, 2)
  nameZh            String               @map("name_zh") @db.VarChar(255)
  nameFr            String?              @map("name_fr") @db.VarChar(255)
  specification     String?              @db.VarChar(100)
  unit              String?              @db.VarChar(100)
  category          String               @db.VarChar(20)
  returnItems       PurchaseReturnItem[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([supplierId])
  @@map("purchase_order_items")
}

model PurchaseReturn {
  id              Int                  @id @default(autoincrement())
  purchaseOrderId Int                  @map("purchase_order_id")
  purchaseOrder   PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  supplierId      Int                  @map("supplier_id")
  supplier        Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  restaurantId    Int                  @map("restaurant_id")
  restaurant      Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  createdByUserId Int                  @map("created_by_user_id")
  createdByUser   User                 @relation("CreatedByUserReturns", fields: [createdByUserId], references: [id], onDelete: Restrict)
  reason          String               @db.VarChar(255)
  notes           String?              @db.Text
  totalItems      Int                  @map("total_items")
  items           PurchaseReturnItem[]
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([purchaseOrderId])
  @@index([restaurantId, createdAt])
  @@index([supplierId, createdAt])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id                  Int               @id @default(autoincrement())
  purchaseReturnId    Int               @map("purchase_return_id")
  purchaseReturn      PurchaseReturn    @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  purchaseOrderItemId Int               @map("purchase_order_item_id")
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Restrict)
  productId           BigInt            @map("product_id") @db.UnsignedBigInt
  product             Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  specificationSlot   Int?              @map("specification_slot")
  quantity            Int
  nameZh              String            @map("name_zh") @db.VarChar(255)
  nameFr              String?           @map("name_fr") @db.VarChar(255)
  specification       String?           @db.VarChar(100)
  unit                String?           @db.VarChar(100)
  category            String            @db.VarChar(20)

  @@index([purchaseReturnId])
  @@index([purchaseOrderItemId])
  @@index([productId])
  @@map("purchase_return_items")
}

model TrainingMaterial {
  id                Int                        @id @default(autoincrement())
  positionId        String                     @map("position_id") @db.VarChar(40)
  type              String                     @db.VarChar(20)
  isRequired        Boolean                    @default(false) @map("is_required")
  title             String                     @db.VarChar(255)
  description       String?                    @db.VarChar(500)
  originalName      String                     @map("original_name") @db.VarChar(255)
  mimeType          String                     @map("mime_type") @db.VarChar(100)
  sizeBytes         BigInt                     @map("size_bytes")
  bucket            String                     @db.VarChar(100)
  objectKey         String                     @unique @map("object_key") @db.VarChar(500)
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")
  progress          TrainingMaterialProgress[]
  quiz              TrainingQuiz?
  badgeRequirements TrainingBadgeRequirement[]

  @@index([positionId])
  @@index([type])
  @@map("training_materials")
}

// Singleton (id = 1) holding HQ-configurable AI quiz-generation settings.
// The API key is stored AES-256-GCM encrypted, never in plaintext.
model AiQuizConfig {
  id        Int      @id @default(1)
  apiKeyEnc String?  @map("api_key_enc") @db.Text
  baseUrl   String?  @map("base_url") @db.VarChar(300)
  model     String?  @db.VarChar(150)
  maxTokens Int?     @map("max_tokens")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ai_quiz_config")
}

model TrainingQuiz {
  id            Int      @id @default(autoincrement())
  materialId    Int      @unique @map("material_id")
  passingScore  Int      @default(80) @map("passing_score")
  maxAttempts   Int?     @map("max_attempts")
  questionCount Int      @default(0) @map("question_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  material  TrainingMaterial       @relation(fields: [materialId], references: [id], onDelete: Cascade)
  questions TrainingQuizQuestion[]
  attempts  TrainingQuizAttempt[]

  @@map("training_quizzes")
}

model TrainingQuizQuestion {
  id           Int      @id @default(autoincrement())
  quizId       Int      @map("quiz_id")
  type         String   @default("single") @db.VarChar(20)
  prompt       String   @db.VarChar(500)
  options      Json
  correctKeys  Json     @map("correct_keys")
  explanation  String?  @db.VarChar(500)
  translations Json?
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  quiz TrainingQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("training_quiz_questions")
}

model TrainingQuizAttempt {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  quizId    Int      @map("quiz_id")
  score     Int
  passed    Boolean  @default(false)
  answers   Json
  createdAt DateTime @default(now()) @map("created_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz TrainingQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId, quizId])
  @@index([quizId])
  @@map("training_quiz_attempts")
}

model ScreenSecurityEvent {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  eventType  String   @default("screenshot") @map("event_type") @db.VarChar(20)
  screenName String?  @map("screen_name") @db.VarChar(100)
  deviceInfo Json?    @map("device_info")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("screen_security_events")
}

model TrainingTitle {
  id                 Int                 @id @default(autoincrement())
  code               String              @unique @db.VarChar(40)
  nameZh             String              @map("name_zh") @db.VarChar(100)
  nameEn             String              @map("name_en") @db.VarChar(100)
  nameFr             String              @map("name_fr") @db.VarChar(100)
  frameStyle         String              @default("red") @map("frame_style") @db.VarChar(40)
  unlockPositionCode String              @map("unlock_position_code") @db.VarChar(40)
  sortOrder          Int                 @default(0) @map("sort_order")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  earned             UserTrainingTitle[]
  equippedByUsers    User[]              @relation("EquippedTrainingTitle")

  @@index([unlockPositionCode])
  @@map("training_titles")
}

model UserTrainingTitle {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  titleCode String   @map("title_code") @db.VarChar(40)
  earnedAt  DateTime @default(now()) @map("earned_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title TrainingTitle @relation(fields: [titleCode], references: [code], onDelete: Cascade)

  @@unique([userId, titleCode])
  @@index([userId])
  @@map("user_training_titles")
}

model TrainingBadge {
  id                     Int                        @id @default(autoincrement())
  code                   String                     @unique @db.VarChar(80)
  nameZh                 String                     @map("name_zh") @db.VarChar(120)
  nameEn                 String                     @map("name_en") @db.VarChar(120)
  nameFr                 String                     @map("name_fr") @db.VarChar(120)
  descriptionZh          String?                    @map("description_zh") @db.VarChar(500)
  descriptionEn          String?                    @map("description_en") @db.VarChar(500)
  descriptionFr          String?                    @map("description_fr") @db.VarChar(500)
  track                  String                     @default("general") @db.VarChar(40)
  rarity                 String                     @default("common") @db.VarChar(20)
  level                  Int?
  iconType               String                     @default("default") @map("icon_type") @db.VarChar(40)
  imageFileName          String?                    @map("image_file_name") @db.VarChar(100)
  requiredScore          Int                        @default(80) @map("required_score")
  requiredCompletionRate Int                        @default(100) @map("required_completion_rate")
  isActive               Boolean                    @default(true) @map("is_active")
  sortOrder              Int                        @default(0) @map("sort_order")
  createdAt              DateTime                   @default(now()) @map("created_at")
  updatedAt              DateTime                   @updatedAt @map("updated_at")
  requirements           TrainingBadgeRequirement[]
  earned                 UserTrainingBadge[]

  @@index([isActive, sortOrder])
  @@index([track])
  @@map("training_badges")
}

model TrainingBadgeRequirement {
  id         Int              @id @default(autoincrement())
  badgeCode  String           @map("badge_code") @db.VarChar(80)
  materialId Int              @map("material_id")
  sortOrder  Int              @default(0) @map("sort_order")
  createdAt  DateTime         @default(now()) @map("created_at")
  badge      TrainingBadge    @relation(fields: [badgeCode], references: [code], onDelete: Cascade)
  material   TrainingMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([badgeCode, materialId])
  @@index([materialId])
  @@map("training_badge_requirements")
}

model UserTrainingBadge {
  id        Int           @id @default(autoincrement())
  userId    Int           @map("user_id")
  badgeCode String        @map("badge_code") @db.VarChar(80)
  earnedAt  DateTime      @default(now()) @map("earned_at")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     TrainingBadge @relation(fields: [badgeCode], references: [code], onDelete: Cascade)

  @@unique([userId, badgeCode])
  @@index([userId])
  @@index([badgeCode])
  @@index([earnedAt])
  @@map("user_training_badges")
}

model TrainingMaterialProgress {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  materialId   Int       @map("material_id")
  status       String    @default("in_progress") @db.VarChar(20)
