PORT=3002
API_PREFIX=api
# Matches docker-compose.yml: host port 3307 -> container 3306, db zhao_family,
# user zhao / dev_pass. After `pnpm db:up` this works out of the box.
# Point elsewhere if running against an existing MySQL.
DATABASE_URL="mysql://zhao:dev_pass@127.0.0.1:3307/zhao_family"
AUTH_TOKEN_SECRET=change_this_local_secret
CORS_ORIGINS="http://localhost:3000,http://localhost:3100"
PASSWORD_RESET_DEBUG=false
BREVO_API_KEY=
MAIL_FROM_EMAIL=no-reply@zhaosfamily.com
MAIL_FROM_NAME="ZHAO Plateforme"
APP_WEB_URL=https://zhaosfamily.com
MAIL_LOGO_URL=https://raw.githubusercontent.com/PPWAURK/ZHAOSFAMILY/main/apps/web/public/logo2024/logo2024.jpg
# Object storage (S3-compatible). Local dev = MinIO. Production = Cloudflare R2.
# For R2: endpoint host only (no https://), port 443, SSL on, region "auto".
#   MINIO_ENDPOINT=<ACCOUNT_ID>.r2.cloudflarestorage.com
#   MINIO_PORT=443
#   MINIO_USE_SSL=true
#   MINIO_REGION=auto
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_password
MINIO_BUCKET=company-private-files
# AI quiz generation (OpenRouter / OpenAI-compatible). Leave AI_API_KEY empty to disable.
# Legacy NVIDIA_* variables are still supported in code for existing deployments.
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_QUIZ_MODEL=deepseek/deepseek-v4-pro
# Max output tokens per generation request. Lower it if OpenRouter returns 402
# (insufficient credits). Default 3000.
AI_MAX_TOKENS=3000
# Optional OpenRouter attribution headers.
AI_HTTP_REFERER=
AI_APP_TITLE=ZHAO Plateforme
