# Backend runtime environment for production (docker compose env_file).
# Copy to apps/backend/.env.production on the server and fill it. Never commit it.
#
# Hostnames below (mysql, minio) are the docker-compose service names — the
# backend reaches them over the internal compose network, not via host ports.

PORT=3002
# Nest global route prefix. With the Nginx sample (location /backend3/ ->
# proxy_pass http://127.0.0.1:3002/, trailing slash strips /backend3), keep
# API_PREFIX empty so public routes are https://api.zhaoplatforme.com/backend3/<route>.
# If instead Nginx forwards the full path unchanged, set API_PREFIX=backend3.
API_PREFIX=

# Must match MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE from the root .env.
DATABASE_URL="mysql://zhao:change_me_db@mysql:3306/zhao_family"

# REQUIRED. HMAC secret for access tokens — generate a long random value, e.g.
#   openssl rand -base64 48
AUTH_TOKEN_SECRET=change_me_long_random_secret

# Comma-separated allowed origins for CORS (the web front-end origin).
CORS_ORIGINS="https://zhaoplatforme.com"

PASSWORD_RESET_DEBUG=false

# Transactional email (Brevo). Leave BREVO_API_KEY empty to disable sending.
BREVO_API_KEY=
MAIL_FROM_EMAIL=no-reply@zhaosfamily.com
MAIL_FROM_NAME="ZHAO Plateforme"
APP_WEB_URL=https://zhaoplatforme.com
MAIL_LOGO_URL=https://raw.githubusercontent.com/PPWAURK/ZHAOSFAMILY/main/apps/web/public/logo2024/logo2024.jpg

# MinIO (object storage). Endpoint is the compose service name.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=zhaominio
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET=company-private-files

# AI quiz generation (OpenRouter / OpenAI-compatible). Leave AI_API_KEY empty to disable.
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_QUIZ_MODEL=deepseek/deepseek-v4-pro
AI_MAX_TOKENS=3000
AI_HTTP_REFERER=
AI_APP_TITLE=ZHAO Plateforme
