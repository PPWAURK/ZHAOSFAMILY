{
  "expo": {
    "name": "ZHAO's Family",
    "slug": "zhao-family-mobile",
    "scheme": "zhaofamily",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/play-store/app-icon-1024.png",
    "splash": {
      "backgroundColor": "#6F0D10"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.zhao.family",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "9"
    },
    "android": {
      "package": "com.zhao.family",
      "adaptiveIcon": {
        "foregroundImage": "./assets/play-store/adaptive-foreground-1024.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "versionCode": 6
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "选择一张头像用于员工档案。",
          "cameraPermission": "拍摄一张头像用于员工档案。",
          "microphonePermission": false
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#6F0D10"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c17788a6-0cf8-491f-a706-5a41349cd914"
      }
    },
    "owner": "panned"
  }
}
