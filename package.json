{
  "name": "zhao-family",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:web": "pnpm --filter @zhao/web dev",
    "dev:mobile": "pnpm --filter @zhao/mobile dev",
    "dev:api": "pnpm --filter backend start:dev",
    "build": "turbo build",
    "build:web": "pnpm --filter @zhao/web build",
    "build:api": "pnpm --filter backend build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mobile:start": "pnpm dev:mobile",
    "mobile:android": "pnpm --filter @zhao/mobile android",
    "mobile:ios": "pnpm --filter @zhao/mobile ios",
    "mobile:test": "pnpm --filter @zhao/mobile test",
    "mobile:lint": "pnpm --filter @zhao/mobile lint",
    "start": "pnpm --filter @zhao/web start",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "db:pull": "pnpm --filter backend prisma:pull",
    "db:push": "pnpm --filter backend prisma:push",
    "db:migrate": "pnpm --filter backend prisma:migrate",
    "db:deploy": "pnpm --filter backend prisma:deploy",
    "db:generate": "pnpm --filter backend prisma:generate",
    "db:seed": "pnpm --filter backend prisma:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "shadcn": "^4.3.0",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "motion": "^12.38.0"
  }
}
