{
  "name": "zhao-family",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run start:dev --workspace=api",
    "dev": "npm-run-all -p dev:web dev:api",
    "build:web": "npm run build --workspace=web",
    "build:api": "npm run build --workspace=api",
    "build": "npm-run-all build:api build:web",
    "start": "npm run start --workspace=web",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "db:migrate": "npm run prisma:migrate --workspace=api",
    "db:generate": "npm run prisma:generate --workspace=api",
    "db:seed": "npm run prisma:seed --workspace=api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "shadcn": "^4.3.0"
  },
  "dependencies": {
    "motion": "^12.38.0"
  }
}
